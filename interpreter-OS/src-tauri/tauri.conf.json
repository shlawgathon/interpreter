{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "interpreter-os",
  "version": "0.1.0",
  "identifier": "app.interpreter.os",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Interpreter OS",
        "label": "main",
        "width": 430,
        "height": 820,
        "minWidth": 390,
        "minHeight": 760,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": true,
        "resizable": true,
        "hiddenTitle": true,
        "x": 40,
        "y": 48
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
